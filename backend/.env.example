# PathGuard Backend Environment Variables Example

# Security
SECRET_KEY="your-super-secret-key-change-me"

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# Additional CORS origins (comma-separated, for production)
# Example: "https://pathguard.vercel.app,https://abc123.ngrok-free.app"
ADDITIONAL_CORS_ORIGINS=""

# Database connection (optional, defaults to SQLite)
# DATABASE_URL="postgresql://user:password@localhost:5432/pathguard"
